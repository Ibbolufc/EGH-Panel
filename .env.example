# ============================================================
# EGH Panel — Environment Variable Reference
# Copy this file to .env and fill in the required values
# ============================================================

# --- Postgres ---
POSTGRES_USER=eghpanel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=eghpanel

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- JWT Authentication ---
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=7d

# --- Application ---
NODE_ENV=production
FRONTEND_URL=http://localhost        # Change to your domain
HTTP_PORT=80
HTTPS_PORT=443                        # Uncomment if you add TLS certs

# --- CORS ---
# Set to your frontend domain in production
CORS_ORIGIN=http://localhost

# --- Session (legacy, kept for compatibility) ---
SESSION_SECRET=CHANGE_ME_SESSION_SECRET
