# ============================================================
# EGH Panel — Environment Variables
# Copy this file to .env and fill in the values marked CHANGE_ME.
#
#   cp .env.example .env
#
# Required values: POSTGRES_PASSWORD, JWT_SECRET
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=eghpanel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=eghpanel

# --- Redis ---
# Redis is wired in docker-compose and reserved for future queue/cache use.
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- JWT Authentication ---
# Must be set — the API server refuses to start without it.
# Generate a secure value: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=7d

# --- Application ---
NODE_ENV=production
# Set to your public domain or server IP. Used for CORS and in the README.
FRONTEND_URL=http://localhost
# Port that nginx exposes on the host. Change if 80 is already in use.
HTTP_PORT=80

# --- HTTPS ---
# EGH Panel does NOT handle TLS internally. Use an external reverse proxy
# (Caddy, Traefik, Cloudflare, host nginx) in front of the panel.
# When HTTPS is set up, change FRONTEND_URL to https://yourdomain.com.
