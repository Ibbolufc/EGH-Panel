# EGH Panel - Environment Configuration
# Copy this file to .env and fill in your values

# Database
DB_PASSWORD=changeme_strong_password_here
DATABASE_URL=postgresql://eghpanel:changeme_strong_password_here@localhost:5432/eghpanel

# Authentication
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
SESSION_SECRET=another-long-random-secret-string

# Server
NODE_ENV=production
PORT=8080
