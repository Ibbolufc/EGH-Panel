# ============================================================
# EGH Panel — Environment Variables
#
# When using the one-command installer (scripts/bootstrap.sh),
# you do NOT need to edit this file manually — POSTGRES_PASSWORD,
# REDIS_PASSWORD, and JWT_SECRET are auto-generated and written
# to .env for you.
#
# For a manual install, copy this file to .env and either:
#   • Let scripts/install.sh auto-generate the secrets, or
#   • Fill in the CHANGE_ME values yourself before running it.
#
#   cp .env.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=eghpanel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=eghpanel

# --- Redis ---
# Used internally; auto-generated by the installer.
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- JWT Authentication ---
# Must be a long random secret — the API server refuses to start without it.
# Generate manually with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=7d

# --- Application ---
NODE_ENV=production
# Set to your public domain or server IP. Used for CORS headers.
FRONTEND_URL=http://localhost
# Port that nginx exposes on the host. Change if 80 is already in use.
HTTP_PORT=80

# --- HTTPS ---
# EGH Panel does NOT handle TLS internally. Use an external reverse proxy
# (Caddy, Traefik, Cloudflare, host nginx) in front of the panel.
# When HTTPS is set up, change FRONTEND_URL to https://yourdomain.com.
